<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base background color - brighter medical blue-white -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background_medical" />
        </shape>
    </item>

    <!-- Soft gradient from top to make it look less flat -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1A0277BD"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>

    <!-- Decorative Circle Top Right - increased opacity -->
    <item android:top="-100dp" android:right="-100dp">
        <shape android:shape="oval">
            <solid android:color="#140277BD" />
            <size android:width="300dp" android:height="300dp" />
        </shape>
    </item>

    <!-- Decorative Circle Bottom Left - increased opacity -->
    <item android:bottom="-50dp" android:left="-50dp">
        <shape android:shape="oval">
            <solid android:color="#120277BD" />
            <size android:width="200dp" android:height="200dp" />
        </shape>
    </item>
</layer-list>